# PM Simulator Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

# =============================================================================
# SECURITY - CHANGE THESE BEFORE DEPLOYMENT!
# =============================================================================

# Generate strong secrets using: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
SECRET_KEY=your-flask-secret-key-change-this-in-production

# PostgreSQL Database Password
DB_PASSWORD=your-secure-database-password

# =============================================================================
# DATABASE
# =============================================================================

POSTGRES_USER=postgres
POSTGRES_DB=pm_simulator

# =============================================================================
# REDIS
# =============================================================================

REDIS_URL=redis://redis:6379/0

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

FLASK_ENV=production
FLASK_DEBUG=0
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@database:5432/pm_simulator

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

NODE_ENV=production
NEXT_PUBLIC_API_URL=http://localhost:5001

# =============================================================================
# LLM CONFIGURATION (Optional)
# =============================================================================

# Ollama (Local LLM - requires significant RAM)
# OLLAMA_URL=http://ollama:11434

# Cloud LLM Providers (Recommended for production)
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# Sentry error tracking
# SENTRY_DSN=your-sentry-dsn

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Docker Hub credentials (for CI/CD)
# DOCKER_USERNAME=your-docker-username
# DOCKER_PASSWORD=your-docker-token

# Server details (for CI/CD)
# SERVER_HOST=your-server-ip-or-domain
# SERVER_USER=deploy
# SERVER_SSH_KEY=path-to-ssh-key

# Slack notifications (for CI/CD)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
