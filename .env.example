# PM Simulator - Environment Configuration Template
# Copy this file to .env.local and fill in your values

# =============================================================================
# USER SIMULATION SERVICE (MiroFish Integration)
# =============================================================================
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:5001
AI_SERVICE_PORT=5001

# =============================================================================
# SECURITY AI AGENT - Telegram Configuration
# =============================================================================
# 1. Open Telegram, search for @BotFather
# 2. Send /newbot, follow prompts to create bot
# 3. Copy the BOT_TOKEN here
# 4. Message your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 5. Find "chat":{"id":123456789} and copy the ID

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=true
TELEGRAM_ALERT_LEVEL=high

# =============================================================================
# SECURITY AI AGENT - Settings
# =============================================================================
SECURITY_AGENT_PORT=5002
PM_SIMULATOR_ROOT=C:/Users/DELL/pm-simulator
