# AI Agents System Configuration
# Copy this file to .env.local and fill in your values

# Anthropic API Configuration (for AI features)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# GitHub API Token (for agent integrations)
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# AI Agents System Path
# Path to your local AI agents installation
AI_AGENTS_SYSTEM_PATH=C:/Users/DELL/ai-agents-system

# Optional: API endpoint if running agents as a service
AI_AGENTS_API_URL=http://localhost:5001

# Feature flags for AI integrations
ENABLE_AI_PRD_GENERATION=true
ENABLE_AI_CODE_REVIEW=true
ENABLE_AI_SECURITY_SCAN=true
ENABLE_AI_AUTO_DOCS=true
ENABLE_AI_MASTERY_COACH=true
