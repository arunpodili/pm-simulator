# Production Environment Variables - PM Simulator v2.0
# Copy to .env.staging and fill in real values

# =============================================================================
# SECURITY - CRITICAL - MUST BE CHANGED FROM DEFAULTS
# =============================================================================

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-256-bit-secret-key-change-this-in-production

# Redis Password (generate strong password)
REDIS_PASSWORD=your-strong-redis-password-change-this

# API Keys (should be from secure vault in production)
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL is constructed from above in tasks.py

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

FLASK_ENV=production
FLASK_DEBUG=false
PORT=5001
HOST=0.0.0.0

# =============================================================================
# RATE LIMITING
# =============================================================================

# Set to 'true' to disable rate limiting (for testing only)
RATE_LIMIT_DISABLED=false

# Redis URL for rate limiting (includes password)
# Format: redis://:password@host:port/db
RATE_LIMIT_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# =============================================================================
# CLEANUP CONFIGURATION
# =============================================================================

# How long to keep simulations (hours)
SIMULATION_TTL_HOURS=24

# Cleanup interval (minutes)
CLEANUP_INTERVAL_MINUTES=30

# Max simulations per user
MAX_SIMULATIONS_PER_USER=10

# =============================================================================
# CELERY CONFIGURATION
# =============================================================================

CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

LLM_DAILY_BUDGET=10.0
OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Prometheus metrics port
# METRICS_PORT=9090
